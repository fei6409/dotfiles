#!/bin/bash
set -e
set -o noclobber

USAGE="Usage: $(basename "$0") [flags] <archive files>
  -h,--help     Show help message
  -n,--native   Use native utilities instead of 'ouch'
"
temp_files=()
use_native=false

cleanup() {
  for file in "${temp_files[@]}"; do
    rm -rf "${file}"
  done
}

info() {
  printf "\e[1;33m%s\e[m\n" "$*"
}

die() {
  printf "\e[1;31mERROR: %s\e[m\n" "$*" >&2
  cleanup
  exit 1
}

cmd_exist() {
  if type "$1" > /dev/null 2>&1; then
    return 0
  fi
  info "Command '$1' not found, fall back to alternative tool"
  return 1
}

atomic_file() {
  { true > "$1"; } &> /dev/null
}

atomic_directory() {
  mkdir -- "$1" 2> /dev/null
}

replace() {
  local src_path="$1"
  local target_name="$2"
  # mv -T is not supported on BSD :(
  local temp_dir
  temp_dir=$(mktemp -d tmp.unarchive.XXXXXXXXXX)
  temp_files+=("${temp_dir}")
  mv -- "${src_path}" "${temp_dir}/${target_name}"
  mv -- "${temp_dir}/${target_name}" .
}

find_unique_name() {
  local orig_name="$1"
  local file_type="$2"
  local name="${orig_name}"
  local ext=""
  if [[ ${file_type} == "file" ]]; then
    local name_without_ext="${orig_name%.*}"
    # The file can be a dotfile with no other extension (e.g. .bashrc)
    name="${name_without_ext:-${orig_name}}"
    if [[ "${orig_name}" != "${name}" ]]; then
      ext=".${orig_name##*.}"
    fi
  fi

  if "atomic_${file_type}" "${name}${ext}"; then
    echo "${name}${ext}"
    return
  fi

  local num=2
  while ! "atomic_${file_type}" "${name}_${num}${ext}"; do
    ((num++))
  done
  echo "${name}_${num}${ext}"
}

unarchive_zip() {
  unzip -d "$2" -- "$1"
}

unarchive_tar() {
  tar -xvf "$1" -C "$2"
}

unarchive_tgz() {
  #shellcheck disable=SC2310
  if cmd_exist "pigz"; then
    tar --use-compress-program pigz -xvf "$1" -C "$2"
  else
    tar -xvzf "$1" -C "$2"
  fi
}

unarchive_txz() {
  #shellcheck disable=SC2310
  if cmd_exist "pixz"; then
    tar --use-compress-program pixz -xvf "$1" -C "$2"
  else
    tar --xz -xvf "$1" -C "$2"
  fi
}

unarchive_tbz2() {
  tar -xvjf "$1" -C "$2"
}

unarchive_7z() {
  7za x -o"$2" -- "$1"
}

unarchive_gzip() {
  local archive
  local archive_basename

  archive="$(basename "$1")"
  # Remove the .gz extension to get the target filename
  archive_basename="${archive%.gz}"

  #shellcheck disable=SC2310
  if cmd_exist "pigz"; then
    pigz -dkc "$1" > "$2/${archive_basename}"
  else
    gzip -dkc "$1" > "$2/${archive_basename}"
  fi
}

unarchive_zst() {
  local archive
  local archive_basename

  archive=$(basename "$1")
  # Remove the .zst extension to get the target filename
  archive_basename="${archive%.zst}"

  zstd -d "$1" -o "$2/${archive_basename}"
}

unarchive_rar() {
  unrar x "$1" "$2"
}

unarchive() {
  local archive_orig_path="$1"
  if [[ ! -f "${archive_orig_path}" ]]; then
    die "${archive_orig_path}: archive doesn't exist."
  fi

  local archive
  archive="$(basename "${archive_orig_path}")"

  local archive_basename="${archive%.*}"
  if [[ "${archive}" == *.tar.* ]]; then
    archive_basename="${archive%.tar.*}"
  fi

  local temp_dir
  temp_dir=$(mktemp -d tmp.unarchive.XXXXXXXXXX)
  temp_files+=("${temp_dir}")

  #shellcheck disable=SC2310
  if [[ "${use_native}" != true ]] && cmd_exist "ouch"; then
    ouch d "${archive_orig_path}" --dir "${temp_dir}" -y
  else
    local archive_type
    case "${archive}" in
      *.zip)
        archive_type=zip
        ;;
      *.tar)
        archive_type=tar
        ;;
      *.tar.gz | *.tgz)
        archive_type=tgz
        ;;
      *.tar.xz | *.txz)
        archive_type=txz
        ;;
      *.tar.bz2 | *.tbz | *.tbz2)
        archive_type=tbz2
        ;;
      *.7z)
        archive_type=7z
        ;;
      *.gz)
        archive_type=gzip
        ;;
      *.zst)
        archive_type=zst
        ;;
      *.rar)
        archive_type=rar
        ;;
      *)
        die "Unknown archive: ${archive_orig_path}"
        ;;
    esac
    "unarchive_${archive_type}" "${archive_orig_path}" "${temp_dir}"
  fi

  local sub_files=()
  mapfile -d '' -t sub_files < <(find "${temp_dir}" -maxdepth 1 -mindepth 1 -print0)

  if (("${#sub_files[@]}" == 0)); then
    info "${archive_orig_path}: No file in archive!"
    return
  fi

  local target
  if (("${#sub_files[@]}" == 1)); then
    local file="${sub_files[0]}"
    local file_type
    file_type=$([[ -f "${file}" ]] && echo "file" || echo "directory")
    target="$(find_unique_name "$(basename "${file}")" "${file_type}")"
    replace "${file}" "${target}"
    info "${archive_orig_path}: Single ${file_type}, moved to ${target}"
  else
    target="$(find_unique_name "${archive_basename}" "directory")"
    replace "${temp_dir}" "${target}"
    info "${archive_orig_path}: Extracted to ${target}"
  fi
}

main() {
  trap cleanup EXIT

  local OPTS
  OPTS=$(getopt -o "hn" -l "help,native" -- "$@") || die "${USAGE}"
  eval set -- "${OPTS}"

  while true; do
    case "$1" in
      -h | --help)
        info "${USAGE}"
        exit 0
        ;;
      -n | --native)
        use_native=true
        shift
        ;;
      --)
        shift
        break
        ;;
      *)
        die "Failed to parse args"
        ;;
    esac
  done

  if (($# == 0)); then
    die "${USAGE}"
  fi

  while (($# > 0)); do
    unarchive "$1"
    shift
  done
}
main "$@"
